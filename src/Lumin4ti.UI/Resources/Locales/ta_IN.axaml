  <!-- ===== Notes / buttons ===== -->
  <x:String x:Key="Text.Note.RequiresReboot" xml:space="preserve">* செயல்பட PC-ஐ மறுதொடக்கம் செய்ய வேண்டும்</x:String>
  <x:String x:Key="Text.Note.LongRunning" xml:space="preserve">* இயங்க சில நிமிடங்கள் ஆகலாம்</x:String>
  <x:String x:Key="Text.Note.AffectsExplorer" xml:space="preserve">* மாற்றும்போது Explorer தானாகவே மறுதொடக்கம் ஆகும்</x:String>
  <x:String x:Key="Text.Button.Run" xml:space="preserve">இயக்கு</x:String>
  <x:String x:Key="Text.Button.Cancel" xml:space="preserve">ரத்துசெய்</x:String>

  <!-- ===== About / version pane ===== -->
  <x:String x:Key="Text.Version.Subtitle" xml:space="preserve">Windows-ஐ உங்கள் விருப்பப்படி தனிப்பயனாக்கும் கருவி</x:String>
  <x:String x:Key="Text.Version.VersionLabel" xml:space="preserve">பதிப்பு:</x:String>
  <x:String x:Key="Text.Version.CheckUpdate" xml:space="preserve">புதுப்பிப்புகளைச் சரிபார்</x:String>
  <x:String x:Key="Text.Version.ShowSkipped" xml:space="preserve">தவிர்த்த புதுப்பிப்பை மீண்டும் காட்டு</x:String>
  <x:String x:Key="Text.Version.CheckOnStartup" xml:space="preserve">தொடக்கத்தில் தானாகவே புதுப்பிப்புகளைச் சரிபார்</x:String>
  <x:String x:Key="Text.Version.LanguageHeader" xml:space="preserve">மொழி</x:String>
  <x:String x:Key="Text.Version.LanguageHint" xml:space="preserve">காட்சி மொழியைத் தேர்ந்தெடுக்கவும்.</x:String>
  <x:String x:Key="Text.Version.FoldersHeader" xml:space="preserve">கோப்புறைகள்</x:String>
  <x:String x:Key="Text.Version.OpenLogs" xml:space="preserve">பதிவு கோப்புறையைத் திற</x:String>
  <x:String x:Key="Text.Version.OpenSettings" xml:space="preserve">அமைப்புகள் கோப்புறையைத் திற</x:String>

  <!-- ===== Category titles / captions ===== -->
  <x:String x:Key="Text.Category.Update" xml:space="preserve">புதுப்பிப்பு &amp; பாதுகாப்பு</x:String>
  <x:String x:Key="Text.Category.Update.Caption" xml:space="preserve">பயன்பாடுகளையும் Windows Defender-ஐயும் புதுப்பித்து, ஆரோக்கியமான பாதுகாப்பு அமைப்புகளை மீட்டமைக்கவும்.</x:String>
  <x:String x:Key="Text.Category.Cleanup" xml:space="preserve">சுத்தம் &amp; பழுதுநீக்கம்</x:String>
  <x:String x:Key="Text.Category.Cleanup.Caption" xml:space="preserve">வட்டு இடத்தை மீட்டு, பழுதடைந்த பதிவுகளைச் சுத்தம் செய்யவும் அல்லது சரிசெய்யவும்.</x:String>
  <x:String x:Key="Text.Category.Performance" xml:space="preserve">செயல்திறன்</x:String>
  <x:String x:Key="Text.Category.Performance.Caption" xml:space="preserve">நினைவகம், செயல்முறைகள் மற்றும் ரெண்டரிங்கை மேம்படுத்தவும். பொதுவாக நிலைமாற்றிகள் ON = மேம்படுத்தலைப் பயன்படுத்து, OFF = Windows இயல்புநிலைக்குத் திரும்பு (MMAgent உருப்படிகள் மட்டும் ON = அந்த அம்சத்தை இயக்கு; பரிந்துரைக்கப்பட்ட மதிப்புக்கு ஒவ்வொரு விளக்கத்தையும் பார்க்கவும்).</x:String>
  <x:String x:Key="Text.Category.System" xml:space="preserve">அமைப்பு</x:String>
  <x:String x:Key="Text.Category.System.Caption" xml:space="preserve">மின்சக்தி, உள்ளீடு, நேரம் போன்ற Windows அமைப்புகளைச் சரிசெய்யவும். நிலைமாற்றிகள் ON = பயன்படுத்து, OFF = Windows இயல்புநிலைக்குத் திரும்பு.</x:String>
  <x:String x:Key="Text.Category.Organize" xml:space="preserve">ஒழுங்குபடுத்து</x:String>
  <x:String x:Key="Text.Category.Organize.Caption" xml:space="preserve">பின்கள், சூழல் மாறிகள் மற்றும் பலவற்றை நேர்த்தியான வரிசையில் அடுக்கவும்.</x:String>

  <!-- ===== Status / result messages ({0} = item name) ===== -->
  <x:String x:Key="Text.Status.Running" xml:space="preserve">{0} இயங்குகிறது…</x:String>
  <x:String x:Key="Text.Status.RunningLong" xml:space="preserve">{0} இயங்குகிறது… (சில நிமிடங்கள் ஆகலாம்)</x:String>
  <x:String x:Key="Text.Status.TogglingOn" xml:space="preserve">{0} ON செய்யப்படுகிறது…</x:String>
  <x:String x:Key="Text.Status.TogglingOff" xml:space="preserve">{0} OFF செய்யப்படுகிறது…</x:String>
  <x:String x:Key="Text.Status.Completed" xml:space="preserve">{0} முடிந்தது</x:String>
  <x:String x:Key="Text.Status.Failed" xml:space="preserve">{0} தோல்வியடைந்தது (பதிவைச் சரிபார்க்கவும்)</x:String>
  <x:String x:Key="Text.Status.ToggledOn" xml:space="preserve">{0} ON செய்யப்பட்டது</x:String>
  <x:String x:Key="Text.Status.ToggledOff" xml:space="preserve">{0} OFF செய்யப்பட்டது</x:String>
  <x:String x:Key="Text.Status.ToggleFailed" xml:space="preserve">{0}-ஐ நிலைமாற்ற முடியவில்லை (பதிவைச் சரிபார்க்கவும்)</x:String>
<x:String x:Key="Text.Status.Cancelled" xml:space="preserve">ரத்துசெய்யப்பட்டது</x:String>
  <x:String x:Key="Text.Status.Busy" xml:space="preserve">மற்றொரு பராமரிப்பு செயல் இயங்குகிறது. அது முடிந்ததும் மீண்டும் முயற்சிக்கவும்.</x:String>
  <x:String x:Key="Text.Result.Success" xml:space="preserve">✓ முடிந்தது</x:String>
  <x:String x:Key="Text.Result.Partial" xml:space="preserve">⚠ பகுதியளவு முடிந்தது</x:String>
  <x:String x:Key="Text.Result.Failure" xml:space="preserve">✗ தோல்வி</x:String>
  <x:String x:Key="Text.Result.ExplorerRestarted" xml:space="preserve">  - Explorer மறுதொடக்கம் செய்யப்பட்டது</x:String>
  <x:String x:Key="Text.Result.ExplorerRestartFailed" xml:space="preserve">  - Explorer-ஐ மறுதொடக்கம் செய்ய முடியவில்லை (கைமுறையாக மறுதொடக்கம் செய்யவும்)</x:String>
  <x:String x:Key="Text.Toggle.StateUnknown" xml:space="preserve">நிலையைப் படிக்க முடியவில்லை (நிர்வாக உரிமை இல்லை, அல்லது இந்த PC-யில் அம்சம் கிடைக்கவில்லை. Debug தொடக்கங்கள் உயர்த்தப்படாதவை, எனவே இயல்பான தொடக்கத்தை முயற்சிக்கவும்).</x:String>

  <!-- ===== Actions: Update &amp; Security ===== -->
  <x:String x:Key="Text.Action.winget-upgrade-all.Label" xml:space="preserve">நிறுவப்பட்ட பயன்பாடுகளை மொத்தமாகப் புதுப்பி (winget)</x:String>
  <x:String x:Key="Text.Action.winget-upgrade-all.Desc" xml:space="preserve">winget தொகுப்பு மேலாளரைப் பயன்படுத்தி நிறுவப்பட்ட அனைத்து பயன்பாடுகளையும் அவற்றின் சமீபத்திய பதிப்புகளுக்கு மேம்படுத்துகிறது. பல பயன்பாடுகளுக்குப் புதுப்பிப்பு தேவைப்பட்டால், பதிவிறக்கமும் நிறுவலும் சிறிது நேரம் எடுக்கலாம். இயங்கிக்கொண்டிருக்கும் பயன்பாடுகளின் இயங்குகோப்புகள் பூட்டப்பட்டு புதுப்பிக்கத் தவறலாம், ஆனால் மற்றவை தொடரும், வெற்றி/தோல்வி விவரப் பட்டியல் காட்டப்படும்.</x:String>
  <x:String x:Key="Text.Action.defender-signature-update.Label" xml:space="preserve">Defender வரையறைக் கோப்புகளை மீண்டும் பெறு</x:String>
  <x:String x:Key="Text.Action.defender-signature-update.Desc" xml:space="preserve">Windows Defender-இன் வைரஸ் வரையறைகளையும் இயங்குநிலைக் கையொப்பங்களையும் ஒருமுறை நீக்கி, சமீபத்தியவற்றை மீண்டும் பதிவிறக்குகிறது. தவறான கண்டறிதல்களை அல்லது புதுப்பிப்புப் பிழைகளை ஏற்படுத்தும் வரையறை சிதைவுக்கான வழக்கமான புதுப்பித்தல்; இயங்கும்போது நிகழ்நேரப் பாதுகாப்பு தொடர்ந்து செயல்படும்.</x:String>
  <x:String x:Key="Text.Action.defender-reset.Label" xml:space="preserve">Defender அமைப்புகளை மீட்டமை (விலக்குகள் &amp; முக்கிய விருப்பங்கள்)</x:String>
  <x:String x:Key="Text.Action.defender-reset.Desc" xml:space="preserve">Windows Defender-இல் பதிவுசெய்யப்பட்ட அனைத்து விலக்குப் பாதைகள், செயல்முறைகள், நீட்டிப்புகளை நீக்கி, நிகழ்நேர மற்றும் கிளவுட் பாதுகாப்பு போன்ற முக்கிய விருப்பங்களை அவற்றின் இயல்புநிலைக்கு மீட்டமைக்கிறது. தீம்பொருள் அல்லது பழைய மென்பொருள் சேர்த்திருக்கக்கூடிய விலக்குகளை (ஸ்கேன் குருட்டுப்புள்ளிகள்) அழிக்கிறது. வேண்டுமென்றே சேர்த்த விலக்குகளும் நீக்கப்படும், எனவே தேவைப்படுவற்றை பின்னர் மீண்டும் சேர்க்கவும்.</x:String>
  <x:String x:Key="Text.Action.security-app-reset.Label" xml:space="preserve">Windows Security பயன்பாட்டை மீட்டமை</x:String>
  <x:String x:Key="Text.Action.security-app-reset.Desc" xml:space="preserve">Windows Security பயன்பாடு திறக்காதபோது, சிதைந்ததாகத் தோன்றும்போது அல்லது உருப்படிகள் காணாமல் போகும்போது, அதை ஆரம்ப நிலைக்கு மீட்டமைத்து மீண்டும் பதிவுசெய்கிறது. Defender-இன் பாதுகாப்பு நிலையையோ வரையறைக் கோப்புகளையோ இது பாதிக்காது.</x:String>

  <!-- ===== Actions: Cleanup &amp; Repair ===== -->
  <x:String x:Key="Text.Action.wu-component-cleanup.Label" xml:space="preserve">Windows Update பயன்படுத்திய இடத்தை நீக்கு</x:String>
  <x:String x:Key="Text.Action.wu-component-cleanup.Desc" xml:space="preserve">உறுப்புச் சேமிப்பில் (WinSxS கோப்புறை) குவிந்த மாற்றப்பட்ட பழைய புதுப்பிப்புத் தலைமுறைகளை நிரந்தரமாக நீக்கி பல GB வட்டு இடத்தை மீட்கிறது. இதற்குப் பிறகு பயன்படுத்திய புதுப்பிப்புகளை நிறுவல் நீக்க முடியாது (பொதுவாக சிக்கல் இல்லை). சில நிமிடங்கள் முதல் பல்லாயிரம் நிமிடங்கள் வரை எடுக்கும்.</x:String>
  <x:String x:Key="Text.Action.repair-shell-folder-names.Label" xml:space="preserve">சிதைந்த கணினி கோப்புறைப் பெயர்களை சரிசெய்</x:String>
  <x:String x:Key="Text.Action.repair-shell-folder-names.Desc" xml:space="preserve">shell32.dll-ஐ மீண்டும் பதிவுசெய்வதன் மூலம், கணினி கோப்புறைப் பெயர்கள் (எ.கா. Downloads) ஆங்கிலத்தில் காட்டப்படுவது போன்ற காட்சிச் சிதைவைச் சரிசெய்கிறது.</x:String>
  <x:String x:Key="Text.Action.tray-icon-reset.Label" xml:space="preserve">கணினி தட்டு ஐகான் தேக்ககத்தை மீட்டமை</x:String>
  <x:String x:Key="Text.Action.tray-icon-reset.Desc" xml:space="preserve">அறிவிப்புப் பகுதி (கணினி தட்டு) ஐகான் தேக்ககத்தை அழிக்கிறது. நிறுவல் நீக்கப்பட்ட பயன்பாடுகளின் ஐகான்கள் மறைந்த ஐகான் பகுதியில் தங்கிவிடும் நிலைமைகளைத் தீர்க்கிறது. உங்கள் தட்டு காட்டு/மறை தனிப்பயனாக்கம் ஒருமுறை மீட்டமைக்கப்படும்.</x:String>
  <x:String x:Key="Text.Action.remove-broken-startup.Label" xml:space="preserve">சிதைந்த தொடக்க உள்ளீடுகளை நீக்கு</x:String>
  <x:String x:Key="Text.Action.remove-broken-startup.Desc" xml:space="preserve">இயங்குகோப்பு இனி இல்லாத தொடக்க உள்ளீடுகளை (தற்போதைய பயனர்) அதற்குரிய அனாதை உள்ளீடுகளுடன் சேர்த்து நீக்குகிறது.</x:String>
  <x:String x:Key="Text.Action.remove-dead-associations.Label" xml:space="preserve">Open-with-இலிருந்து இல்லாத பயன்பாடுகளை நீக்கு</x:String>
  <x:String x:Key="Text.Action.remove-dead-associations.Desc" xml:space="preserve">இயங்குகோப்பு இனி இல்லாத பயன்பாடுகளை Open-with வேட்பாளர் பட்டியலிலிருந்தும் Applications பதிவிலிருந்தும் நீக்குகிறது.</x:String>
  <x:String x:Key="Text.Action.event-log-clear.Label" xml:space="preserve">Event Viewer பதிவுகள் அனைத்தையும் நீக்கு</x:String>
  <x:String x:Key="Text.Action.event-log-clear.Desc" xml:space="preserve">பதிவுச் சேமிப்புப் பகுதியை (பொதுவாக பல நூறு MB) விடுவிக்க Event Viewer-இல் குவிந்த அனைத்து சேனல்களின் பதிவுகளையும் நீக்குகிறது. கடந்தகால சரிசெய்தல் தகவலும் இழக்கப்படும், எனவே சமீபத்திய சிக்கலை ஆராயும்போது இதை இயக்க வேண்டாம். சில பாதுகாக்கப்பட்ட கணினி பதிவுகள் தவிர்க்கப்படும்.</x:String>
  <x:String x:Key="Text.Action.store-cache-reset.Label" xml:space="preserve">Microsoft Store தேக்ககத்தை அழி</x:String>
  <x:String x:Key="Text.Action.store-cache-reset.Desc" xml:space="preserve">WSReset மூலம் Microsoft Store தேக்ககத்தை மீட்டமைக்கிறது. Store திறக்காமல் இருப்பது, பதிவிறக்கங்கள் முன்னேறாதது அல்லது மீண்டும் மீண்டும் “try again” பிழைகளுக்கான வழக்கமான தீர்வு. பயன்பாடுகளும் கணக்குத் தகவலும் நீக்கப்படாது. முடிந்ததும் Store பயன்பாடு தானாகவே திறக்கலாம்.</x:String>
  <x:String x:Key="Text.Action.ssd-trim.Label" xml:space="preserve">SSD TRIM மற்றும் காலி இட ஒருங்கிணைப்பு</x:String>
  <x:String x:Key="Text.Action.ssd-trim.Desc" xml:space="preserve">SSD எழுதும் செயல்திறனைப் பராமரிக்கவும் காலி இடத்தைத் துண்டழிக்கவும் அனைத்து தொகுதிகளிலும் SSD-க்கு TRIM அறிவிப்பையும் (/L) காலி இட ஒருங்கிணைப்பையும் (/X) இயக்குகிறது. இயக்கி அமைப்பைப் பொறுத்து சில நிமிடங்கள் முதல் பல்லாயிரம் நிமிடங்கள் வரை எடுக்கலாம். இயங்கும்போது PC-ஐத் தொடர்ந்து பயன்படுத்தலாம்.</x:String>

  <!-- ===== Actions: Performance ===== -->
  <x:String x:Key="Text.Action.mmagent-memory-compression.Label" xml:space="preserve">Memory Compression</x:String>
  <x:String x:Key="Text.Action.mmagent-memory-compression.Desc" xml:space="preserve">நினைவகம் குறையும்போது வட்டுக்கு மாற்றுவதற்கு முன் RAM-இல் உள்ள பக்கங்களை அழுத்தி, பயனுள்ள கொள்ளளவை அதிகரிக்கிறது. சிறிதளவு CPU சுமைக்குப் பதிலாக swap தொடர்பான மந்தநிலையையும் SSD எழுதுதல்களையும் குறைக்கிறது. பரிந்துரை: ON (Windows இயல்புநிலையும் ON).</x:String>
  <x:String x:Key="Text.Action.mmagent-page-combining.Label" xml:space="preserve">Page Combining</x:String>
  <x:String x:Key="Text.Action.mmagent-page-combining.Desc" xml:space="preserve">ஒரே உள்ளடக்கம் கொண்ட நினைவகப் பக்கங்களை ஒன்றாக இணைத்து, நகல்தன்மையை நீக்குகிறது. ஒரே வகையான பல பயன்பாடுகளை இயக்கும்போது நினைவகத்தைச் சேமிக்கிறது. பரிந்துரை: ON (சில பதிப்புகளில் இயல்புநிலை OFF).</x:String>
  <x:String x:Key="Text.Action.mmagent-operation-api.Label" xml:space="preserve">Operation Recorder API</x:String>
  <x:String x:Key="Text.Action.mmagent-operation-api.Desc" xml:space="preserve">SysMain (முன்பு Superfetch) செயல்பாட்டை பதிவுசெய்து மீண்டும் இயக்க வெளிப்புறக் கருவிகளுக்கான API. இயல்பான பயன்பாட்டில் பயன்படுத்தப்படாத, பெஞ்ச்மார்க்கிங் மற்றும் செயல்திறன் பகுப்பாய்வுக் கருவிகளுக்கானது. பரிந்துரை: OFF (Windows இயல்புநிலையும் OFF).</x:String>
  <x:String x:Key="Text.Action.mmagent-launch-prefetch.Label" xml:space="preserve">பயன்பாடு தொடக்க முன்கொணர்வு</x:String>
  <x:String x:Key="Text.Action.mmagent-launch-prefetch.Desc" xml:space="preserve">அடிக்கடி பயன்படுத்தப்படும் பயன்பாடுகள் ஏற்றும் கோப்புகளைக் கற்று, தொடக்கத்தை விரைவுபடுத்த அவற்றை தொடக்கத்தில் முன்கொணர்கிறது (Prefetch). SSD-களிலும் தொடக்கக் காத்திருப்பைக் குறைக்க உதவுகிறது. பரிந்துரை: ON (Windows இயல்புநிலையும் ON).</x:String>
  <x:String x:Key="Text.Action.mmagent-prelaunch.Label" xml:space="preserve">UWP பயன்பாடு முன்-தொடக்கம்</x:String>
  <x:String x:Key="Text.Action.mmagent-prelaunch.Desc" xml:space="preserve">விரைவில் பயன்படுத்தப்படக்கூடிய Store (UWP) பயன்பாடுகளை முன்கணித்து, நீங்கள் திறப்பதற்கு முன்பே அவற்றை பின்னணியில் தொடங்குகிறது. வேகமாக உணரப்படுகிறது ஆனால் முன்கூட்டியே நினைவகத்தைப் பயன்படுத்துகிறது, எனவே நினைவகச் சேமிப்புக்கு முன்னுரிமை கொடுத்தால் OFF பரிந்துரைக்கப்படுகிறது.</x:String>
  <x:String x:Key="Text.Action.paging-executive-reset.Label" xml:space="preserve">Kernel paging அமைப்பை இயல்புநிலைக்கு மீட்டமை</x:String>
  <x:String x:Key="Text.Action.paging-executive-reset.Desc" xml:space="preserve">மேம்படுத்தல் கருவிகள் அடிக்கடி எழுதும் DisablePagingExecutive (kernel குறியீட்டை எப்போதும் RAM-இல் வைத்திருக்கும் அமைப்பு) நீக்கி, Windows-இன் இயல்புநிலை paging நடத்தைக்குத் திரும்புகிறது. நவீன Windows-இல் இந்த அமைப்புக்குச் சிறிதளவே பயன், நினைவகத்தை வீணடிக்கலாம். இது அமைக்கப்படாத PC-களில் எதுவும் செய்யாது.</x:String>
  <x:String x:Key="Text.Action.vbs-hvci-off.Label" xml:space="preserve">VBS / HVCI-ஐ முடக்கு (1–2 GB நினைவகம் சேமிக்கும்)</x:String>
  <x:String x:Key="Text.Action.vbs-hvci-off.Desc" xml:space="preserve">எப்போதும் ஒதுக்கப்படும் ~1–2 GB நினைவகத்தை விடுவிக்க Virtualization-Based Security (VBS) மற்றும் Hypervisor-Enforced Code Integrity (HVCI) ஆகியவற்றை முடக்குகிறது. இது பாதுகாப்புடன் ஒரு பரிமாற்றம்; Hyper-V, WSL2, Windows Sandbox, Docker Desktop அல்லது Credential Guard பயன்படுத்தினால் OFF (இயல்புநிலை) ஆகவே விடுங்கள்.</x:String>
  <x:String x:Key="Text.Action.svchost-split-threshold.Label" xml:space="preserve">SvcHost செயல்முறைகளை ஒருங்கிணை (பிரிப்பை அடக்கு)</x:String>
  <x:String x:Key="Text.Action.svchost-split-threshold.Desc" xml:space="preserve">இயல்பாக Windows svchost.exe-ஐ ஒவ்வொரு அம்சத்துக்கும் தனித்தனியாக (3.5 GB-க்கு மேல் RAM உள்ள PC-களில்) தொடங்கும். இதை ON செய்வது பிரிப்பு வரம்பை அதிகபட்சமாக்கி, குழுவாக்கக்கூடிய சேவைகளை குறைவான செயல்முறைகளாக ஒருங்கிணைத்து, செயல்முறை எண்ணிக்கையையும் நினைவகப் பயன்பாட்டையும் (பல்லாயிரம் MB) குறைக்கிறது. பாதுகாப்பு எல்லைகளாகக் கருதப்படும் சேவைகள் (DiagTrack, Dnscache போன்றவை) ஒருங்கிணைக்கப்படாது. OFF வரம்பை நீக்கி இயல்புநிலைப் பிரிப்புக்குத் திரும்பும்.</x:String>
  <x:String x:Key="Text.Action.uwp-background-off.Label" xml:space="preserve">UWP பின்னணி இயக்கத்தை மொத்தமாக அணை (200–500 MB சேமிக்கும்)</x:String>
  <x:String x:Key="Text.Action.uwp-background-off.Desc" xml:space="preserve">அனைத்து Store (UWP) பயன்பாடுகளின் பின்னணி இயக்கத்தையும் ஒரே நேரத்தில் “எப்போதும் அணை” என அமைக்கிறது, எனவே நீங்கள் மூடிய பிறகு அவை பின்னணியில் இயங்குவதை நிறுத்தும். தங்குதலைக் குறைப்பது சுமார் 200–500 MB நினைவகத்தைச் சேமிக்கலாம். அறிவிப்புகள் அல்லது நேரடி டைல்கள் தேவைப்படும் பயன்பாடுகளுக்கு, இதை OFF செய்யவும் அல்லது அமைப்புகளில் தனித்தனியாக “எப்போதும் இயக்கு” என மாற்றவும்.</x:String>
  <x:String x:Key="Text.Action.recall-off.Label" xml:space="preserve">Windows Recall-ஐ முடக்கு</x:String>
  <x:String x:Key="Text.Action.recall-off.Desc" xml:space="preserve">AI தேடலுக்காக அவ்வப்போது திரை ஸ்னாப்ஷாட்களைப் பதிவுசெய்யும் Recall அம்சத்தை முடக்குகிறது (Click-to-do, சொற்பொருள் தேடல் போன்ற பிற AI அம்சங்கள் தக்கவைக்கப்படும்). பதிவு செயல்முறையின் நினைவகம்/வட்டு நுகர்வையும் தனியுரிமைக் கவலைகளையும் குறைக்கிறது. Windows 11 24H2 + Copilot+ PC-களில் மட்டுமே கிடைக்கும்; ஆதரிக்கப்படாத PC-களில் நிலையைப் படிக்கவோ நிலைமாற்றவோ முடியாது.</x:String>
  <x:String x:Key="Text.Action.power-throttling-off.Label" xml:space="preserve">Power throttling-ஐ முடக்கு</x:String>
  <x:String x:Key="Text.Action.power-throttling-off.Desc" xml:space="preserve">மின்சக்தியைச் சேமிக்க பின்னணி செயல்முறைகளின் CPU கடிகாரத்தை தானாகவே குறைக்கும் Power Throttling-ஐ முடக்குகிறது. பதிவு, குறியாக்கம், கட்டமைப்பு போன்ற பின்னணி வேலைகள் மந்தமாவதைத் தடுக்கிறது. எப்போதும் முழு செயல்திறனில் இயங்குவதால், மடிக்கணினிகளில் பேட்டரி வடிதல் அதிகரிக்கும். OFF இயல்புநிலை மின்சேமிப்பு நடத்தைக்குத் திரும்பும்.</x:String>
  <x:String x:Key="Text.Action.mpo-off.Label" xml:space="preserve">MPO-ஐ முடக்கு (Multi-Plane Overlay)</x:String>
  <x:String x:Key="Text.Action.mpo-off.Desc" xml:space="preserve">GPU பல தளங்களை ஒருங்கமைக்கும் Multi-Plane Overlay (MPO) அம்சத்தை முடக்குகிறது (OverlayTestMode=5). இயக்கியைப் பொறுத்து MPO திரை மினுமினுப்பு, தற்காலிக கருமையாதல், வீடியோ தடங்கலை ஏற்படுத்தலாம்; அந்த அறிகுறிகள் இருக்கும்போது வழக்கமான தீர்வு. இல்லையெனில், OFF (இயல்புநிலை) ஆக விடுவது நல்லது.</x:String>
  <x:String x:Key="Text.Action.audio-priority.Label" xml:space="preserve">ஆடியோ செயலாக்க முன்னுரிமையை உயர்த்து</x:String>
  <x:String x:Key="Text.Action.audio-priority.Desc" xml:space="preserve">அதிக சுமையின் கீழ் ஆடியோ இடைவெளிகளையும் ஒலிச் சிதறல்களையும் குறைக்க Multimedia Class Scheduler-இன் Playback/Capture பணிகளின் முன்னுரிமையை அதிகபட்ச மதிப்புக்கு (6) உயர்த்துகிறது. OFF முன்னுரிமை அமைப்பை நீக்கி Windows இயல்புநிலைக்குத் திரும்பும்.</x:String>
  <x:String x:Key="Text.Action.rdp-framerate.Label" xml:space="preserve">Remote Desktop-ஐ 60 FPS ஆக்கு</x:String>
  <x:String x:Key="Text.Action.rdp-framerate.Desc" xml:space="preserve">Remote Desktop இணைப்புகளின் வரையும் சட்ட இடைவெளியைக் (DWMFRAMEINTERVAL=15) குறைத்து, இயல்பான ~30 FPS-இலிருந்து சுமார் 60 FPS ஆக உயர்த்துகிறது. இணைக்கப்படும் பக்கமாக இந்த PC-க்கு இது பொருந்தும். அலைவரிசைப் பயன்பாடு அதிகரிக்கும். OFF இயல்பான சட்ட வீதத்திற்குத் திரும்பும்.</x:String>
  <x:String x:Key="Text.Action.startup-speedup.Label" xml:space="preserve">தொடக்க பயன்பாடு தொடங்கும் தாமதத்தை நீக்கு</x:String>
  <x:String x:Key="Text.Action.startup-speedup.Desc" xml:space="preserve">Windows டெஸ்க்டாப்பை வரைவதற்கு முன்னுரிமை கொடுக்க, உள்நுழைவுக்குப் பிறகு தொடக்க பயன்பாடுகளை சில முதல் பன்னிரண்டு வினாடிகள் தாமதப்படுத்தும் பொறிமுறையை (idle காத்திருப்பு + தாமத டைமர்) முடக்குகிறது. தங்கியிருக்கும் கருவிகளை உடனடியாகப் பயன்படுத்தத் தொடங்க விரும்பும்போது பயனுள்ளது. உள்நுழைவுக்குப் பிந்தைய தருணம் சற்று கனமாக உணரப்படலாம். OFF இயல்புநிலை தாமத நடத்தைக்குத் திரும்பும்.</x:String>
  <x:String x:Key="Text.Action.nvidia-msi-fix.Label" xml:space="preserve">NVIDIA GPU குறுக்கீடு விநியோகத்தை மேம்படுத்து</x:String>
  <x:String x:Key="Text.Action.nvidia-msi-fix.Desc" xml:space="preserve">கடந்தகால மேம்படுத்தல் கருவிகள் NVIDIA GPU-க்கு எழுதிய MSI குறுக்கீடு வரம்பை (MessageNumberLimit) நீக்கி, குறுக்கீடு கையாளுதலை இயல்புநிலை விநியோக நடத்தைக்குத் திருப்புகிறது. இந்த மதிப்பு இருந்தால், GPU குறுக்கீடுகள் CPU core 0-இல் குவிந்து விளையாட்டுகளில் தடங்கலை ஏற்படுத்தலாம். NVIDIA GPU இல்லாத PC-களில் எதுவும் மாற்றாது.</x:String>

  <!-- ===== Actions: System ===== -->
  <x:String x:Key="Text.Action.hibernate-off.Label" xml:space="preserve">Hibernation-ஐ முடக்கு</x:String>
  <x:String x:Key="Text.Action.hibernate-off.Desc" xml:space="preserve">Hibernation-ஐ முடக்கி, கணினி இயக்கியில் எப்போதும் ஒதுக்கப்படும் hiberfil.sys (இயற்பியல் நினைவகத்தின் பல சதவீதம் = பல GB) நீக்குகிறது. அதே நேரத்தில் Fast Startup முடக்கப்படும், எனவே தொடக்கம் மெதுவாகலாம். மடிக்கணினியில் hibernation பயன்படுத்தினால் OFF (இயல்புநிலை) ஆக விடுங்கள்.</x:String>
  <x:String x:Key="Text.Action.mouse-accel-off.Label" xml:space="preserve">Mouse acceleration-ஐ முடக்கு (Enhance pointer precision)</x:String>
  <x:String x:Key="Text.Action.mouse-accel-off.Desc" xml:space="preserve">மவுஸை எவ்வளவு வேகமாக நகர்த்துகிறீர்கள் என்பதற்கேற்ப கர்சர் பயணம் மாறும் “Enhance pointer precision”-ஐ (mouse acceleration) முடக்கி, கை மற்றும் கர்சர் அசைவை 1:1 ஆக நிலைப்படுத்துகிறது. FPS போன்ற விளையாட்டுகளில் aim-ஐ நிலைப்படுத்தும் வழக்கமான அமைப்பு. OFF Windows இயல்புநிலைக்குத் (acceleration இயக்கம்) திரும்பும். செயல்பட மறு-உள்நுழைவு தேவைப்படலாம்.</x:String>
  <x:String x:Key="Text.Action.sticky-keys-off.Label" xml:space="preserve">Sticky Keys போன்ற அணுகல் ஹாட்கீகளை முடக்கு</x:String>
  <x:String x:Key="Text.Action.sticky-keys-off.Desc" xml:space="preserve">Shift-ஐ ஐந்து முறை அழுத்தும்போது Sticky Keys இயங்குவது போன்ற, தற்செயலாக அணுகல் அம்சங்களைத் தூண்டும் ஹாட்கீகளை (Sticky Keys / Toggle Keys / Filter Keys) முடக்குகிறது. விளையாட்டுகளில் Shift-ஐ மீண்டும் மீண்டும் அழுத்தும்போது உரையாடல் தோன்றி இடையூறு செய்யும் விபத்துகளைத் தடுக்கிறது. OFF Windows இயல்புநிலைக்குத் (ஹாட்கீகள் இயக்கம்) திரும்பும்.</x:String>
  <x:String x:Key="Text.Action.menu-delay-zero.Label" xml:space="preserve">மெனு காட்சி தாமதத்தைக் குறை</x:String>
  <x:String x:Key="Text.Action.menu-delay-zero.Desc" xml:space="preserve">வலது-கிளிக் மெனுக்களும் Start மெனு துணைமெனுக்களும் திறப்பதற்கு முந்தைய காத்திருப்பை இயல்பான 400 ms-இலிருந்து 0 ஆகக் குறைத்து, UI-ஐ விறுவிறுப்பாக உணரவைக்கிறது. OFF இயல்பான 400 ms-க்குத் திரும்பும். செயல்பட மறு-உள்நுழைவு (அல்லது Explorer மறுதொடக்கம்) தேவை.</x:String>
  <x:String x:Key="Text.Action.folder-template-general.Label" xml:space="preserve">கோப்புறை காட்சி டெம்ப்ளேட்டை General ஆக நிலைப்படுத்து</x:String>
  <x:String x:Key="Text.Action.folder-template-general.Desc" xml:space="preserve">கோப்புறை உள்ளடக்கத்திலிருந்து காட்சி பாணியை (Pictures / Music / Documents போன்றவை) தானாகக் கண்டறிவதை Explorer-ஐத் தடுத்து, அனைத்து கோப்புறைகளையும் General Items ஆக ஒருங்கிணைக்கிறது. பல கோப்புகள் உள்ள கோப்புறைகளில் தானியங்கு கண்டறிதலால் ஏற்படும் மெதுவான காட்சியை (பச்சை முன்னேற்றப் பட்டை) தீர்க்கிறது. OFF தானியங்கு கண்டறிதலுக்குத் திரும்பும்.</x:String>
  <x:String x:Key="Text.Action.ceip-off.Label" xml:space="preserve">CEIP / கருத்து அறிவிப்புகளை முடக்கு</x:String>
  <x:String x:Key="Text.Action.ceip-off.Desc" xml:space="preserve">Customer Experience Improvement Program (CEIP, Microsoft-க்கு பயன்பாட்டுத் தரவை அனுப்புவது) மற்றும் “Windows பற்றி கருத்து தெரிவிக்கவும்” அறிவிப்புகளை முடக்குகிறது. அனுப்புதலின் பின்னணி சுமை மற்றும் தனியுரிமை இரண்டிற்கும் வழக்கமான அமைப்பு. OFF கொள்கைகளை நீக்கி இயல்புநிலைக்குத் திரும்பும்.</x:String>
  <x:String x:Key="Text.Action.gamedvr-reset.Label" xml:space="preserve">Game Bar / Game DVR அமைப்புகளை இயல்புநிலைக்கு மீட்டமை</x:String>
  <x:String x:Key="Text.Action.gamedvr-reset.Desc" xml:space="preserve">கடந்தகால மேம்படுத்தல் கருவிகள் அல்லது ரெஜிஸ்ட்ரி மாற்றங்கள் எழுதிய Game Bar / Game DVR (விளையாட்டு பதிவு) முடக்க அமைப்புகளை நீக்கி, Windows-இன் இயல்புநிலை நடத்தைக்குத் திரும்புகிறது. “Win+G பதிலளிக்கவில்லை” அல்லது “விளையாட்டுகளைப் படம்பிடிக்க முடியவில்லை” போன்ற அறிகுறிகளுக்குப் பயனுள்ளது.</x:String>
  <x:String x:Key="Text.Action.nvme-driver-revert.Label" xml:space="preserve">NVMe நேட்டிவ் இயக்கியின் வலிந்த இயக்கத்தை மாற்று</x:String>
  <x:String x:Key="Text.Action.nvme-driver-revert.Desc" xml:space="preserve">Windows-இன் சோதனை NVMe நேட்டிவ் இயக்கியை வலிந்து இயக்கும் FeatureManagement மேலெழுதலை நீக்கி, சேமிப்பக இயக்கியை OS இயல்புநிலை முடிவுக்குத் திருப்புகிறது. இந்த மேலெழுதல் இருந்தால், சில சூழல்களில் நீல திரையை (PAGE_FAULT_IN_NONPAGED_AREA) ஏற்படுத்தலாம். மேலெழுதல் இல்லாத PC-களில் எதுவும் மாற்றாது.</x:String>
  <x:String x:Key="Text.Action.ntp-config.Label" xml:space="preserve">நேர ஒத்திசைவு சேவையகத்தை ஜப்பானிய NTP ஆக அமை</x:String>
  <x:String x:Key="Text.Action.ntp-config.Desc" xml:space="preserve">நேர ஒத்திசைவு துல்லியத்தையும் நிலைத்தன்மையையும் மேம்படுத்த, Windows-இன் நேர ஒத்திசைவு இலக்கை இயல்பான time.windows.com-இலிருந்து ஜப்பானிய பொது NTP சேவையகத்திற்கு (ntp.jst.mfeed.ad.jp) மாற்றுகிறது. உடனடியாகச் செயல்படுத்த பின்னர் Windows Time சேவையை மறுதொடக்கம் செய்கிறது.</x:String>

  <!-- ===== Actions: Organize ===== -->
  <x:String x:Key="Text.Action.quick-access-sort.Label" xml:space="preserve">Quick Access பின்களை வரிசைப்படுத்து</x:String>
  <x:String x:Key="Text.Action.quick-access-sort.Desc" xml:space="preserve">Quick Access-இல் பின் செய்யப்பட்ட கோப்புறைகளைப் பாதை மூலம் ஏறுவரிசையில் வரிசைப்படுத்துகிறது (இயக்குவதற்கு முன் ஜம்ப் பட்டியலை காப்புப் பிரதி எடுக்கிறது).</x:String>
  <x:String x:Key="Text.Action.env-path-sort.Label" xml:space="preserve">Path சூழல் மாறியை வரிசைப்படுத்து</x:String>
  <x:String x:Key="Text.Action.env-path-sort.Desc" xml:space="preserve">பயனர் மற்றும் கணினி Path சூழல் மாறிகளின் உள்ளீடுகளை நகல்நீக்கி ஏறுவரிசையில் வரிசைப்படுத்துகிறது.</x:String>
  <x:String x:Key="Text.Action.edge-background-off.Label" xml:space="preserve">Edge பின்னணி செயல்களை முடக்கு (100–300 MB சேமிக்கும்)</x:String>
  <x:String x:Key="Text.Action.edge-background-off.Desc" xml:space="preserve">கொள்கை மூலம் Edge பின்னணி முறை மற்றும் Startup Boost ஆகியவற்றை முடக்குகிறது. Edge-ஐ அரிதாகப் பயன்படுத்தினால் சுமார் 100–300 MB நினைவகத்தை விடுவிக்கலாம். Edge தொடக்கம் சற்று மெதுவாகலாம்; நீட்டிப்பு அறிவிப்புகள் வராமல் போகலாம். கொள்கைகளை நீக்கி Edge இயல்புநிலைகளை மீட்டமைக்க இதை OFF செய்யவும்.</x:String>
</ResourceDictionary>

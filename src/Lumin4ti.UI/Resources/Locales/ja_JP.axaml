<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!--
    日本語はコード内の日本語マスター (各アクションの Label/Description、カテゴリ Caption、ステータス文言) を
    フォールバックとして使うため、ここには XAML の {DynamicResource} が直接参照するシェル文言だけを持つ。
    (Category/Status/Result/Action.* は App.Text のフォールバックで日本語になる)
  -->
  <x:String x:Key="Text.Tab.Update" xml:space="preserve">更新・セキュリティ</x:String>
  <x:String x:Key="Text.Tab.Cleanup" xml:space="preserve">クリーンアップ・修復</x:String>
  <x:String x:Key="Text.Tab.Performance" xml:space="preserve">パフォーマンス</x:String>
  <x:String x:Key="Text.Tab.System" xml:space="preserve">システム設定</x:String>
  <x:String x:Key="Text.Tab.Organize" xml:space="preserve">整理・ソート</x:String>
  <x:String x:Key="Text.Tab.Version" xml:space="preserve">バージョン情報</x:String>

  <x:String x:Key="Text.Note.RequiresReboot" xml:space="preserve">※ 反映には PC の再起動が必要です</x:String>
  <x:String x:Key="Text.Note.LongRunning" xml:space="preserve">※ 実行に数分かかることがあります</x:String>
  <x:String x:Key="Text.Note.AffectsExplorer" xml:space="preserve">※ 変更時にエクスプローラーを自動再起動します</x:String>

  <x:String x:Key="Text.Button.Run" xml:space="preserve">実行</x:String>
  <x:String x:Key="Text.Button.Cancel" xml:space="preserve">中断</x:String>

  <x:String x:Key="Text.Version.Subtitle" xml:space="preserve">Windows を自分好みに整えるカスタマイズツール</x:String>
  <x:String x:Key="Text.Version.VersionLabel" xml:space="preserve">バージョン:</x:String>
  <x:String x:Key="Text.Version.CheckUpdate" xml:space="preserve">更新を確認</x:String>
  <x:String x:Key="Text.Version.ShowSkipped" xml:space="preserve">スキップした更新を再表示</x:String>
  <x:String x:Key="Text.Version.CheckOnStartup" xml:space="preserve">起動時に自動で更新を確認する</x:String>
  <x:String x:Key="Text.Version.LanguageHeader" xml:space="preserve">言語</x:String>
  <x:String x:Key="Text.Version.LanguageHint" xml:space="preserve">表示言語を選びます。</x:String>
  <x:String x:Key="Text.Version.FoldersHeader" xml:space="preserve">フォルダ</x:String>
  <x:String x:Key="Text.Version.OpenLogs" xml:space="preserve">ログフォルダを開く</x:String>
  <x:String x:Key="Text.Version.OpenSettings" xml:space="preserve">設定フォルダを開く</x:String>
  <x:String x:Key="Text.Action.edge-background-off.Label" xml:space="preserve">Edge のバックグラウンド常駐を無効化 (メモリ節約 100〜300MB)</x:String>
  <x:String x:Key="Text.Action.edge-background-off.Desc" xml:space="preserve">Microsoft Edge のバックグラウンドモードと Startup Boost をポリシーで無効化します。Edge を常用しない場合は約 100〜300MB のメモリを節約できます。Edge の起動が少し遅くなり、拡張機能の通知が届かなくなる場合があります。OFF にするとポリシーを削除して Edge の既定値へ戻します。</x:String>
  <x:String x:Key="Text.Status.Busy" xml:space="preserve">別のメンテナンス操作が実行中です。完了後にもう一度お試しください。</x:String>
  <x:String x:Key="Text.Result.Partial" xml:space="preserve">⚠ 一部完了しました</x:String>
</ResourceDictionary>

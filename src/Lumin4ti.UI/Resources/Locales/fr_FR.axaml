  <!-- ===== Tabs ===== -->
  <x:String x:Key="Text.Tab.Update" xml:space="preserve">Mise à jour &amp; Sécurité</x:String>
  <x:String x:Key="Text.Tab.Cleanup" xml:space="preserve">Nettoyage &amp; Réparation</x:String>
  <x:String x:Key="Text.Tab.Performance" xml:space="preserve">Performances</x:String>
  <x:String x:Key="Text.Tab.System" xml:space="preserve">Système</x:String>

  <!-- ===== Tabs ===== -->
  <x:String x:Key="Text.Tab.Update" xml:space="preserve">Update at Seguridad</x:String>
  <x:String x:Key="Text.Tab.Cleanup" xml:space="preserve">Paglilinis at Pag-aayos</x:String>
  <x:String x:Key="Text.Tab.Performance" xml:space="preserve">Performance</x:String>
  <x:String x:Key="Text.Tab.System" xml:space="preserve">System</x:String>
  <x:String x:Key="Text.Tab.Organize" xml:space="preserve">Ayusin</x:String>

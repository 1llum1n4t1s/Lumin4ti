  <!-- ===== Notes / buttons ===== -->
  <x:String x:Key="Text.Note.RequiresReboot" xml:space="preserve">* Erfordert einen PC-Neustart, um wirksam zu werden</x:String>
  <x:String x:Key="Text.Note.LongRunning" xml:space="preserve">* Kann einige Minuten dauern</x:String>
  <x:String x:Key="Text.Note.AffectsExplorer" xml:space="preserve">* Explorer wird bei Änderung automatisch neu gestartet</x:String>

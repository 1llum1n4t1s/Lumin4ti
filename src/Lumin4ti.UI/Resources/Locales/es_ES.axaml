  <!-- ===== Tabs ===== -->
  <x:String x:Key="Text.Tab.Update" xml:space="preserve">Actualización y seguridad</x:String>
  <x:String x:Key="Text.Tab.Cleanup" xml:space="preserve">Limpieza y reparación</x:String>
  <x:String x:Key="Text.Tab.Performance" xml:space="preserve">Rendimiento</x:String>
  <x:String x:Key="Text.Tab.System" xml:space="preserve">Sistema</x:String>

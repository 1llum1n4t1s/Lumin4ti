<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Lumin4ti.UI.ViewModels"
        xmlns:views="using:Lumin4ti.UI.Views"
        x:Class="Lumin4ti.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Lumin4ti"
        Icon="avares://Lumin4ti.UI/icon/app.ico"
        Width="880" Height="620" MinWidth="760" MinHeight="500"
        Background="Transparent"
        ExtendClientAreaTitleBarHeightHint="32"
        ExtendClientAreaToDecorationsHint="True"
        TransparencyLevelHint="AcrylicBlur"
        WindowStartupLocation="CenterScreen">

  <Panel>
    <!--  ウィンドウ背景：アクリルブラー (Shisui / Lhamiel と同じ Tahoe 風ガラス質感)  -->
    <ExperimentalAcrylicBorder IsHitTestVisible="False">
      <ExperimentalAcrylicBorder.Material>
        <ExperimentalAcrylicMaterial
            BackgroundSource="Digger"
            MaterialOpacity="0.85"
            TintColor="{DynamicResource Color.Window}"
            TintOpacity="0.9" />
      </ExperimentalAcrylicBorder.Material>
    </ExperimentalAcrylicBorder>

    <Grid Margin="16,36,16,16">
      <TabControl Classes="sidebar">
        <TabItem>
          <TabItem.Header>
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <!--  更新アイコン (循環矢印)  -->
              <Canvas Width="16" Height="16">
                <Path Data="M 13.5,8 A 5.5,5.5 0 1 1 8,2.5"
                      Stroke="{DynamicResource Brush.FG1}" StrokeThickness="1.4" StrokeLineCap="Round" />
                <Path Data="M 8,0.5 L 11,2.5 L 8,4.5 Z" Fill="{DynamicResource Brush.FG1}" />
              </Canvas>
              <TextBlock Text="{DynamicResource Text.Tab.Update}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
            </StackPanel>
          </TabItem.Header>
          <views:CommandCategoryView DataContext="{Binding Update}" />
        </TabItem>
        <TabItem>
          <TabItem.Header>
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <!--  ほうきアイコン (掃除)  -->
              <Canvas Width="16" Height="16">
                <Line StartPoint="12,1" EndPoint="7,8" Stroke="{DynamicResource Brush.FG1}" StrokeThickness="1.4" StrokeLineCap="Round" />
                <Path Data="M 7,8 L 3,14 L 10,11 Z" Stroke="{DynamicResource Brush.FG1}" StrokeThickness="1.3" StrokeJoin="Round" />
              </Canvas>
              <TextBlock Text="{DynamicResource Text.Tab.Cleanup}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
            </StackPanel>
          </TabItem.Header>
          <views:CommandCategoryView DataContext="{Binding Cleanup}" />
        </TabItem>
        <TabItem>
          <TabItem.Header>
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <!--  稲妻アイコン (パフォーマンス)  -->
              <Canvas Width="16" Height="16">
                <Path Data="M 9,1 L 3,9 L 7,9 L 6,15 L 13,6 L 8.5,6 Z"
                      Stroke="{DynamicResource Brush.FG1}" StrokeThickness="1.3" StrokeJoin="Round" />
              </Canvas>
              <TextBlock Text="{DynamicResource Text.Tab.Performance}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
            </StackPanel>
          </TabItem.Header>
          <views:CommandCategoryView DataContext="{Binding Performance}" />
        </TabItem>
        <TabItem>
          <TabItem.Header>
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <!--  歯車アイコン (システム設定)  -->
              <Canvas Width="16" Height="16">
                <Ellipse Width="10" Height="10" Canvas.Left="3" Canvas.Top="3"
                         Stroke="{DynamicResource Brush.FG1}" StrokeThickness="1.4" />
                <Ellipse Width="3.6" Height="3.6" Canvas.Left="6.2" Canvas.Top="6.2"
                         Fill="{DynamicResource Brush.FG1}" />
                <Line StartPoint="8,0.8" EndPoint="8,3" Stroke="{DynamicResource Brush.FG1}" StrokeThickness="1.6" />
                <Line StartPoint="8,13" EndPoint="8,15.2" Stroke="{DynamicResource Brush.FG1}" StrokeThickness="1.6" />
                <Line StartPoint="0.8,8" EndPoint="3,8" Stroke="{DynamicResource Brush.FG1}" StrokeThickness="1.6" />
                <Line StartPoint="13,8" EndPoint="15.2,8" Stroke="{DynamicResource Brush.FG1}" StrokeThickness="1.6" />
              </Canvas>
              <TextBlock Text="{DynamicResource Text.Tab.System}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
            </StackPanel>
          </TabItem.Header>
          <views:CommandCategoryView DataContext="{Binding System}" />
        </TabItem>
        <TabItem>
          <TabItem.Header>
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <!--  ソートアイコン (長さ順の 3 本線)  -->
              <Canvas Width="16" Height="16">
                <Line StartPoint="2,4" EndPoint="14,4" Stroke="{DynamicResource Brush.FG1}" StrokeThickness="1.4" StrokeLineCap="Round" />
                <Line StartPoint="2,8" EndPoint="10,8" Stroke="{DynamicResource Brush.FG1}" StrokeThickness="1.4" StrokeLineCap="Round" />
                <Line StartPoint="2,12" EndPoint="6,12" Stroke="{DynamicResource Brush.FG1}" StrokeThickness="1.4" StrokeLineCap="Round" />
              </Canvas>
              <TextBlock Text="{DynamicResource Text.Tab.Organize}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
            </StackPanel>
          </TabItem.Header>
          <views:CommandCategoryView DataContext="{Binding Organize}" />
        </TabItem>
        <TabItem>
          <TabItem.Header>
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <!--  情報アイコン (i)  -->
              <Canvas Width="16" Height="16">
                <Ellipse Width="14" Height="14" Canvas.Left="1" Canvas.Top="1"
                         Stroke="{DynamicResource Brush.FG1}" StrokeThickness="1.3" />
                <Line StartPoint="8,7" EndPoint="8,11.5" Stroke="{DynamicResource Brush.FG1}" StrokeThickness="1.6" />
                <Ellipse Width="2" Height="2" Canvas.Left="7" Canvas.Top="4" Fill="{DynamicResource Brush.FG1}" />
              </Canvas>
              <TextBlock Text="{DynamicResource Text.Tab.Version}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
            </StackPanel>
          </TabItem.Header>
          <views:VersionView DataContext="{Binding Version}" />
        </TabItem>
      </TabControl>
    </Grid>
  </Panel>
</Window>
